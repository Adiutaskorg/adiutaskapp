# ============================================
# UniBot PWA — Environment Variables
# ============================================
# Copy this file to .env and fill in the values

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Database ---
DATABASE_URL=./data/unibot.db

# --- Canvas LMS ---
CANVAS_BASE_URL=https://ufv.instructure.com
CANVAS_API_TOKEN=your_canvas_admin_token_here

# --- Authentication (UFV SSO/CAS) ---
SSO_BASE_URL=https://sso.ufv.es
SSO_CLIENT_ID=unibot-app
SSO_CLIENT_SECRET=your_sso_secret_here
SSO_CALLBACK_URL=http://localhost:3000/api/auth/callback

# --- JWT ---
JWT_SECRET=change_this_to_a_secure_random_string
JWT_EXPIRES_IN=7d

# --- OpenAI (LLM Tier 3) ---
OPENAI_API_KEY=sk-your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# --- Web Push Notifications ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=mailto:unibot@ufv.es

# --- Telegram (coexistence) ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# --- Client (prefixed with VITE_ to be exposed to frontend) ---
VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000/ws
VITE_VAPID_PUBLIC_KEY=
