# ============================================
# Railway (backend) environment variables
# ============================================

PORT=3000
NODE_ENV=production
JWT_SECRET=your-jwt-secret-here

# CORS — set to your Vercel frontend URL
CORS_ORIGIN=https://your-app.vercel.app

# SQLite database path (use Railway Volume mounted at /data)
DATABASE_URL=/data/adiutask.db

# Canvas LMS
CANVAS_BASE_URL=https://your-canvas-instance.instructure.com

# SSO / OAuth
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_REDIRECT_URI=

# Anthropic (required — needed for AI chat)
ANTHROPIC_API_KEY=

# Admin emails (comma-separated, for /api/admin/* endpoints)
ADMIN_EMAILS=

# Web Push (optional — needed for push notifications)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your@email.com

# ============================================
# Vercel (frontend) environment variables
# ============================================

# API URL — points to Railway backend (for fetch requests)
VITE_API_URL=https://your-app.up.railway.app

# WebSocket URL — points directly to Railway backend
VITE_WS_URL=wss://your-app.up.railway.app

# VAPID public key for push subscriptions (optional)
VITE_VAPID_PUBLIC_KEY=
