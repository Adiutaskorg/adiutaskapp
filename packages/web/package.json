{
  "name": "adiutask-pwa",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"bun run dev:client\" \"bun run dev:server\"",
    "dev:client": "vite",
    "dev:server": "bun --watch server/index.ts",
    "build": "vite build",
    "preview": "vite preview",
    "start": "bun server/index.ts",
    "db:seed": "bun server/db/seed.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "@adiutask/core": "*",
    "@anthropic-ai/sdk": "^0.78.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "framer-motion": "^11.1.0",
    "lucide-react": "^0.372.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.23.0",
    "rehype-sanitize": "^6.0.0",
    "web-push": "^3.6.7",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "bun-types": "^1.1.0",
    "concurrently": "^8.2.2",
    "eslint": "^9.2.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vite-plugin-pwa": "^0.20.0"
  }
}
