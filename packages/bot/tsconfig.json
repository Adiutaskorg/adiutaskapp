{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "paths": {
      "@adiutask/core": ["../core/src/index.ts"]
    },
    "baseUrl": "."
  },
  "include": ["src", "../core/src"],
  "exclude": ["node_modules", "dist"]
}
